<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}{% if title and site.name not in title %} | {{ site.name }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <meta property="og:title" content="{{ ogTitle or title }}">
  <meta property="og:description" content="{{ ogDescription or description or site.description }}">
  <meta property="og:image" content="{{ ogImage or site.defaultOgImage }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <link rel="canonical" href="{{ canonicalUrl or (site.url + page.url) }}">
  <link rel="stylesheet" href="/css/fonts.css">
  <link rel="stylesheet" href="/css/content.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="icon" type="image/svg+xml" href="/assets/logos/ppl-favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/logos/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/logos/favicon-16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/logos/apple-touch-icon.png">
  {% if schema %}
  <script type="application/ld+json">{{ schema | jsonLd | safe }}</script>
  {% endif %}
</head>
<body>
  {% include "partials/header.njk" %}
  <main class="site-wrap site-main">
    {{ content | safe }}
  </main>
  <div class="site-wrap">
    {% include "partials/footer.njk" %}
  </div>
  <script src="/js/subscribe.js" defer></script>
</body>
</html>
