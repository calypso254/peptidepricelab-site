{# Site masthead — matches the canvas design exactly.
   Nav order + labels: The Index · Start Here · Plain Language ·
   Editor's Notes · News · Sources · Dispatch.

   "The Index" links to /peptides/ (the research-notes index) — the
   editorial name used in the design.

   Hamburger + drawer fire from the @container query in content.css when
   the viewport is narrow; the inline script only toggles the open class. #}

<header class="site-header" data-component="masthead">
  <a href="/" class="logo" aria-label="{{ site.name }} home">
    <span class="logo-mark" aria-hidden="true">P<i class="bead"></i>P<i class="bead bead--accent"></i>L</span>
    <span class="logo-word">Peptide Price Lab</span>
  </a>

  {# Desktop nav #}
  <nav aria-label="Primary">
    <a href="/peptides/"       {% if '/peptides/'       in page.url %}aria-current="page"{% endif %}>The Index</a>
    <a href="/start-here/"     {% if '/start-here/'     in page.url %}aria-current="page"{% endif %}>Start Here</a>
    <a href="/plain-language/" {% if '/plain-language/' in page.url %}aria-current="page"{% endif %}>Plain Language</a>
    <a href="/notes/"          {% if '/notes/'          in page.url %}aria-current="page"{% endif %}>Editor's Notes</a>
    <a href="/news/"           {% if '/news/'           in page.url %}aria-current="page"{% endif %}>News</a>
    <a href="/sources/"        {% if '/sources/'        in page.url %}aria-current="page"{% endif %}>Sources</a>
    <a href="/dispatch/"       {% if '/dispatch/'       in page.url %}aria-current="page"{% endif %}>Dispatch</a>
  </nav>
  <a href="{{ site.appUrl }}" class="btn-launch">Open the Tool &rarr;</a>

  {# Mobile hamburger #}
  <button class="hamburger" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="primary-drawer">
    <span class="hamburger-lines" aria-hidden="true">
      <span></span><span></span><span></span>
    </span>
    <span class="hamburger-text">Menu</span>
  </button>

  {# Mobile drawer — same items + order as desktop nav #}
  <div class="drawer" id="primary-drawer" aria-hidden="true">
    <a href="/peptides/"       {% if '/peptides/'       in page.url %}aria-current="page"{% endif %}>The Index       <span class="drawer-num">01</span></a>
    <a href="/start-here/"     {% if '/start-here/'     in page.url %}aria-current="page"{% endif %}>Start Here      <span class="drawer-num">02</span></a>
    <a href="/plain-language/" {% if '/plain-language/' in page.url %}aria-current="page"{% endif %}>Plain Language  <span class="drawer-num">03</span></a>
    <a href="/notes/"          {% if '/notes/'          in page.url %}aria-current="page"{% endif %}>Editor's Notes  <span class="drawer-num">04</span></a>
    <a href="/news/"           {% if '/news/'           in page.url %}aria-current="page"{% endif %}>News            <span class="drawer-num">05</span></a>
    <a href="/sources/"        {% if '/sources/'        in page.url %}aria-current="page"{% endif %}>Sources         <span class="drawer-num">06</span></a>
    <a href="/dispatch/"       {% if '/dispatch/'       in page.url %}aria-current="page"{% endif %}>Dispatch        <span class="drawer-num">07</span></a>
    <a href="{{ site.appUrl }}" class="btn-launch">Open the Tool &rarr;</a>
  </div>
</header>

<script>
  (function () {
    var hdr = document.querySelector('.site-header');
    if (!hdr) return;
    var btn = hdr.querySelector('.hamburger');
    var drawer = hdr.querySelector('.drawer');
    var txt = btn && btn.querySelector('.hamburger-text');
    if (!btn || !drawer) return;
    btn.addEventListener('click', function () {
      var open = drawer.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
      if (txt) txt.textContent = open ? 'Close' : 'Menu';
    });
    drawer.addEventListener('click', function (e) {
      if (e.target.tagName === 'A') {
        drawer.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
        drawer.setAttribute('aria-hidden', 'true');
        if (txt) txt.textContent = 'Menu';
      }
    });
  })();
</script>
